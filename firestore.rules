rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'thisfaaaa@gmail.com' ||
        request.auth.uid == 'CWrbNLeVJEWlqasbUl1Etn2PqAR2'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Connection test
    match /test/connection {
      allow read: if true;
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Candidates
    match /candidates/{candidateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Votes
    match /votes/{voteId} {
      // rule for creating/updating a vote
      // voteId is userId_categoryId
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() 
        && request.resource.data.userId == request.auth.uid
        && voteId == request.auth.uid + "_" + request.resource.data.categoryId;
        
      allow update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && resource.data.userId == request.auth.uid;
        
      allow delete: if isAdmin();
    }
  }
}
